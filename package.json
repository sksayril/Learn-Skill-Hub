{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@workspace/skill-mission-india",
    "dev:api": "npm run dev --workspace=@workspace/api-server",
    "dev:mockup": "npm run dev --workspace=@workspace/mockup-sandbox",
    "build": "npm run build --workspace=@workspace/skill-mission-india",
    "start": "npm run start --workspace=@workspace/skill-mission-india",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "codegen": "npm run codegen --workspace=@workspace/api-spec",
    "db:push": "npm run push --workspace=@workspace/db"
  },
  "private": true,
  "dependencies": {
    "next": "^15.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "esbuild": "0.27.3"
  }
}
